#!/usr/bin/env sh
#
# Enforced quality gate (AR-12). Established in Story 1.1 and NOT deferred to
# Epic 3 — this is the regression gate that guards every subsequent story
# (there is no CI in v1). Any failure below blocks the commit.
#
# Runs the FAST suite by default ('-m "not slow"'): the single real-port
# uvicorn smoke test is 'slow'-marked and excluded here for speed.
#
# Installed once via:  git config core.hooksPath .githooks
set -e

echo "[pre-commit] ruff check"
uv run ruff check .

echo "[pre-commit] ruff format --check"
uv run ruff format --check .

echo "[pre-commit] pytest (fast suite)"
uv run pytest -m "not slow" -q

echo "[pre-commit] OK"
